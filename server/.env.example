PORT=4100
JWT_SECRET=change-me-in-production
DB_CLIENT=sqlite          # or "pg"
SQLITE_PATH=./catering.db
DATABASE_URL=             # required when DB_CLIENT=pg

CORS_ORIGIN=              # comma-separated origins in production, blank = allow all (dev only)

# Seed admin account (used by `npm run seed`)
SEED_ADMIN_EMAIL=manager@dosmezclas.com
SEED_ADMIN_PASSWORD=catering123
SEED_ADMIN_NAME=Dos Mezclas Manager

# Optional — email sending. Leave all blank to skip email entirely (site still works).
# Works with Gmail (use an App Password, not your normal password), SendGrid SMTP, Mailgun SMTP, etc.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Dos Mezclas Catering" <catering@dosmezclas.com>

# Optional — who receives the internal "new lead" notification email every
# time someone submits the catering form. Defaults to SMTP_USER if blank.
NOTIFY_EMAIL=manager@dosmezclas.com

# Optional — link to the admin dashboard, included in the owner notification email.
ADMIN_URL=

# Optional — Square checkout / payment link for the 30% deposit.
# Create a fixed-price "Catering Deposit" item in Square Dashboard > Online
# Checkout > Payment Links, or generate one per-order via the Square API.
SQUARE_PAYMENT_LINK=
